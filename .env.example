# ── Backend (port 3000) ───────────────────────────────────────────────────────
PORT=3000

# ── MCP Server (port 3001) ────────────────────────────────────────────────────
MCP_PORT=3001

# Set to "false" to connect to real SAP via Flow MCP
USE_MOCK=true

FLOW_API_KEY=jux8l5taT5QVpngFY6rVLoCTe3YyVVk9_yEyFYstz4o
FLOW_MCP_URL=https://flow.pillir.ai/mcp/sse

# ── QA MCP Server (port 3002) — uses qa-server.js ────────────────────────────
# QA endpoint requires X-FLOW-API-KEY + mcp-protocol-version: 2024-11-05
QA_MCP_PORT=3002
FLOW_API_KEY_QA=your-qa-api-key-here
FLOW_MCP_URL_QA=https://qa.flow.pillir.ai/mcp/sse

# ── Google Gemini API Keys (for AI Agent) ─────────────────────────────────────
# Multiple keys for automatic rotation when quota limits are reached
GEMINI_API_KEY_1=your-first-api-key-here
GEMINI_API_KEY_2=your-second-api-key-here